# ── AI Provider ────────────────────────────────────────────────────────────
# Set ONE of the following. Auto-detected in order: GROQ > GEMINI > ANTHROPIC
# Or force: AI_PROVIDER=groq|gemini|anthropic

# FREE — Groq (recommended): https://console.groq.com → API Keys
# 14,400 req/day free · llama-3.3-70b-versatile · very fast
GROQ_API_KEY=

# FREE — Google Gemini: https://aistudio.google.com → Get API key
# 1,500 req/day free · gemini-1.5-flash
GEMINI_API_KEY=

# PAID — Anthropic Claude (most capable): https://console.anthropic.com
# ~$0.01–0.03 per analysis · claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ── App Auth ────────────────────────────────────────────────────────────────
# Shared secret sent as X-API-Key header by the frontend.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-generate-a-strong-random-secret

# ── Facebook Marketplace Scraping ───────────────────────────────────────────
# Path to Playwright persistent profile (stores Facebook session cookies).
# First run: set FB_HEADLESS=false, trigger any search, log into Facebook.
FB_PROFILE_PATH=./fb-profile
FB_HEADLESS=true

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_DB_PATH=./cache.db

# ── Logging / Environment ────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=dev    # set to "production" to hide /docs and strip server headers

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Proxy Rotation (optional) ────────────────────────────────────────────────
PROXY_LIST=

# ── Frontend env vars (frontend/.env or Vercel env vars) ─────────────────────
VITE_API_KEY=change-me-generate-a-strong-random-secret   # must match API_KEY
VITE_API_BASE_URL=          # e.g. https://fb-vehicle-search-api.fly.dev (blank = local)
VITE_DEMO_MODE=true         # set to false once backend is deployed
