# Copy to backend/.env and fill in values

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret that clients must send as X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-generate-a-strong-random-secret

# ── Scraper ───────────────────────────────────────────────────────────────────
# Path to a persistent Chromium profile where you've logged into Facebook once.
# Windows example: C:/Users/YourName/AppData/Local/fb-playwright-profile
FB_PROFILE_PATH=./fb-profile

# Set to false to watch the browser scrape (useful for debugging)
FB_HEADLESS=true

# ── Optional ──────────────────────────────────────────────────────────────────
CACHE_DB_PATH=./cache.db
LOG_LEVEL=INFO
ENV=dev   # set to "production" to disable /docs and /openapi.json

# Comma-separated list of allowed CORS origins (no wildcards)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (.env in frontend/) ──────────────────────────────────────────────
# Must match API_KEY above
VITE_API_KEY=change-me-generate-a-strong-random-secret
